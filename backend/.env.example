# ===========================================
# DevLens Backend Environment Variables
# ===========================================

# Database (Production - MySQL)
DB_URL=jdbc:mysql://localhost:3306/devlens?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=devlens
DB_PASSWORD=your_password_here

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server
SERVER_PORT=8080

# Claude API (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here
