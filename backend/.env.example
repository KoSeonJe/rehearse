# === Database ===
DB_URL=jdbc:mysql://db:3306/rehearse?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=rehearse
DB_PASSWORD=your_db_password_here
DB_ROOT_PASSWORD=your_root_password_here

# === Application ===
SPRING_PROFILES_ACTIVE=dev
CLAUDE_API_KEY=your_claude_api_key_here

# === Frontend / CORS ===
# OAuth 성공 시 리다이렉트 대상
FRONTEND_URL=https://dev.rehearse.co.kr
# 예: https://dev.rehearse.co.kr 또는 https://your-cloudfront-domain.cloudfront.net
CORS_ALLOWED_ORIGINS=https://dev.rehearse.co.kr

# === AWS ===
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-2

# === ECR (docker compose pull 시 필요) ===
ECR_REGISTRY=123456789.dkr.ecr.ap-northeast-2.amazonaws.com
